# 忽略图片预览文件
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.bmp

# 忽略备份目录
backup_before_preset_*/

# 忽略示例工作流文件（可能包含大型数据）
# 但 naiba-test 项目自身的 workflows/ 下的示例工作流需纳入版本控制
# （每次在 ComfyUI 修改后自动同步到本项目中），故在此重新包含：
*官流*.json
!workflows/*.json

# 忽略其他可能的大文件
*.mp4
*.wav
*.mp3

# 忽略临时目录
-p/

# 忽略favorites中的图片（预览图）
favorites/images/

# 忽略用户预设目录（包含用户自定义预设）
presets/
# 但保留目录结构：克隆后默认存在 presets/ 空目录（仅跟踪占位文件）
!presets/.gitkeep

# 忽略预设目录中的预览图（如果存在）
# presets/*.png
# presets/*.jpg

# 忽略CodeBuddy内部数据
.codebuddy/

# 忽略favorites目录（包含预览图等）
favorites/

# 忽略IDE和编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 忽略Python缓存文件
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 忽略 sha256 匹配节点的本地缓存（查询结果 + 预览图）
.sha256_previews/
.sha256_query_cache.json

# 忽略监控进程PID文件
.watcher.pid

# 忽略标签画廊预览图磁盘缓存（见 naiba_tag_picker 的 cache_enabled）
preview_cache/

# 忽略PowerShell自动监视和同步脚本
start-watcher.ps1
stop-watcher.ps1
sync.ps1
watch-and-sync.ps1

# 忽略系统文件
.DS_Store
Thumbs.db