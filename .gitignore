# 忽略图片预览文件
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.bmp

# 忽略备份目录
backup_before_preset_*/

# 忽略示例工作流文件（可能包含大型数据）
*示例工作流*.json
*官流*.json

# 忽略其他可能的大文件
*.mp4
*.wav
*.mp3

# 忽略临时目录
-p/

# 忽略favorites中的图片（预览图）
favorites/images/

# 忽略预设目录中的预览图（如果存在）
# presets/*.png
# presets/*.jpg

# 忽略CodeBuddy内部数据
.codebuddy/

# 忽略favorites目录（包含预览图等）
favorites/

# 忽略IDE和编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 忽略Python缓存文件
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 忽略监控进程PID文件
.watcher.pid

# 忽略系统文件
.DS_Store
Thumbs.db